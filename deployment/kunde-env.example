# ==== KUNDEN-KONFIGURATION ====
# Vor-Ort-Setup: diese 5 Felder mit Kunde gemeinsam ausfüllen.

# IMAP-Zugang (Kunde nennt E-Mail-Adresse + Passwort + gewünschten KI-Ordner-Namen)
IMAP_USER=<info@tankstelle-name.de>
IMAP_PASSWORD=<app-password-oder-mail-password>
IMAP_DRAFTS_FOLDER=<KI-Entwürfe>   # Wird automatisch angelegt falls nicht vorhanden
OWN_EMAIL_ADDRESS=<info@tankstelle-name.de>  # Meistens identisch zu IMAP_USER

# LLM-Provider + API-Key (Vizionists stellt aus Business-Account)
# LLM_PROVIDER: anthropic | openai | google (Vizpatch-WebUI leitet dies automatisch
# aus dem Key-Präfix ab — bei manueller .env-Bearbeitung ohne WebUI selbst setzen)
LLM_PROVIDER=anthropic
LLM_API_KEY=<sk-ant-xxx>

# ==== OPTIONAL — Nur setzen wenn Auto-Detect fehlschlägt ====
# Der Agent erkennt IMAP-Host aus der E-Mail-Domain automatisch.
# Unterstützte Provider: GMX, Web.de, IONOS, T-Online, Gmail, Outlook/M365, Mailbox.org, Strato, Hetzner.
# Manuelle Overrides:
# IMAP_HOST=imap.eigener-server.de
# IMAP_PORT=993
# IMAP_USE_SSL=true
# IMAP_SENT_FOLDER=Sent

# ==== DEFAULTS — Normalerweise nicht ändern ====
IMAP_INBOX_FOLDER=INBOX
POLL_INTERVAL_SECONDS=300
BACKFILL_DAYS=1
OWN_DISPLAY_NAME=<Tankstelle Name>
MODEL_CLASSIFY=claude-haiku-4-5
MODEL_DRAFT=claude-sonnet-4-6
LLM_MAX_TOKENS_DRAFT=600
LLM_TEMPERATURE_DRAFT=0.3
ENABLE_PII_REDACTION=true
LOG_LEVEL=INFO
CONTEXT_FILE=/config/context.md
STATE_DB=/data/state.db
PROMPTS_DIR=/app/prompts

# ==== WEBUI (Phase 4) ====
# WEBUI_USER: Login für Browser-UI. Zufallswert empfohlen: openssl rand -base64 12
WEBUI_USER=admin
# WEBUI_PASSWORD: Muss VOR erstem Start gesetzt werden (nie Default lassen!)
WEBUI_PASSWORD=<setzen-vor-erstem-start>
# AUTOSTART_ENABLED: true = beim Server-Start via systemd. Siehe install-autostart.sh
AUTOSTART_ENABLED=false
# DOCKER_GID: Wird von install-autostart.sh mit echter Host-GID überschrieben
DOCKER_GID=999

# ==== AGENTEN-CHAT (Phase 7) — Kosten-/Missbrauchsschutz, Defaults meist ok ====
# CHAT_RATE_LIMIT_PER_MIN: Max. Chat-Nachrichten pro Minute (pro Client-IP)
CHAT_RATE_LIMIT_PER_MIN=20
# CHAT_MAX_TOKENS: Hartes Token-Limit pro Chat-Antwort (Kostensicherheitsnetz)
CHAT_MAX_TOKENS=2000
# CHAT_HISTORY_TOKEN_BUDGET: Token-Budget für den mitgeschickten Chat-Verlauf
# im Prompt (ältere Turns fallen zuerst weg, wenn das Budget überschritten wird)
CHAT_HISTORY_TOKEN_BUDGET=3000
