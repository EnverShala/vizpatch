# ============================================================
# Vizpatch .env — Manuelle Override-Vorlage
# ============================================================
#
# WICHTIG: Im Zero-Config-Modell (Standard seit v1.1.0) füllt der
# Kunde diese Datei NICHT selbst aus. Die WebUI schreibt sie beim
# Speichern des Formulars automatisch nach /config/.env.
#
# Diese Vorlage ist nur dokumentiert für:
#   1) Manuelle Overrides (headless Setups ohne WebUI)
#   2) Referenz welche Env-Vars der Agent kennt
#   3) Post-Install-Debugging
#
# ============================================================

# ==== IMAP (Pflicht) ====
# E-Mail-Adresse dient gleichzeitig als OWN_EMAIL_ADDRESS (Own-Sender-Filter).
IMAP_USER=info@meinefirma.de
IMAP_PASSWORD=xxx-app-password-xxx

# Drafts-Ordner: LEER LASSEN für Auto-Discovery (empfohlen).
# Der Agent detektiert bei Startup via IMAP SPECIAL-USE (RFC 6154, \Drafts-Flag).
# Wenn Server das nicht announciert → Fallback provider_config.py (GMX="Entwürfe",
# Gmail="[Gmail]/Drafts", IONOS="Entwürfe/Drafts", …).
# Nur setzen um Auto-Discovery zu überschreiben:
# IMAP_DRAFTS_FOLDER=Drafts

# Optional — Auto-Detection für Host/Port/SSL greift für die 10 großen deutschen +
# internationalen Provider. Nur setzen für selfhoster oder unbekannte Hoster:
# IMAP_HOST=imap.mein-eigener-server.de
# IMAP_PORT=993
# IMAP_USE_SSL=true
# IMAP_SENT_FOLDER=Sent
# IMAP_INBOX_FOLDER=INBOX

# ==== Anthropic LLM (Pflicht) ====
ANTHROPIC_API_KEY=sk-ant-xxx

# ==== WebUI-Login (optional) ====
# LEER lassen → kein Login-Schutz + Warnbanner in der UI.
# Bei Verwendung: bcrypt-Hash (nie Klartext). Die WebUI hasht beim Speichern
# automatisch — manuell erzeugen mit:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'MEINPASSWORT', bcrypt.gensalt()).decode())"
# WEBUI_USER=admin
# WEBUI_PASSWORD=$2b$12$....

# ==== Verhalten (optional, Defaults sind vernünftig) ====
POLL_INTERVAL_SECONDS=300
BACKFILL_DAYS=1
# OWN_EMAIL_ADDRESS wird automatisch aus IMAP_USER abgeleitet — nur setzen
# bei exotischen Aliases/Multi-Sender-Setups.
# OWN_EMAIL_ADDRESS=info@meinefirma.de
OWN_DISPLAY_NAME=Meine Firma

# ==== LLM-Tuning (optional) ====
MODEL_CLASSIFY=claude-haiku-4-5
MODEL_DRAFT=claude-sonnet-4-6
LLM_MAX_TOKENS_DRAFT=600
LLM_TEMPERATURE_DRAFT=0.3

# ==== Feature-Flags (optional) ====
# Steuert die reversible Pseudonymisierung strukturierter PII (E-Mail, Telefon,
# IBAN, Kreditkarte, URL, Datum) ueber ALLE LLM-Pfade (Klassifikation, Draft,
# Stil-Extraktion, Agenten-Chat inkl. Tool-Argumente) hinweg (v1.6). Ersetzung
# ist lokal + reversibel (getypte Platzhalter, RAM-only-Mapping) - Namen/Orte
# werden NICHT maskiert. "false" = Klartext an den KI-Anbieter wie vor v1.6.
ENABLE_PII_REDACTION=true
LOG_LEVEL=INFO
AUTOSTART_ENABLED=false

# ==== Pfade (Container-intern, nicht ändern) ====
CONTEXT_FILE=/config/context.md
STATE_DB=/data/state.db
PROMPTS_DIR=/app/prompts

# ==== Docker-Socket-GID (Compose-Level, für WebUI-Container) ====
# Wird typischerweise via `export DOCKER_GID=$(stat -c '%g' /var/run/docker.sock)` gesetzt.
# DOCKER_GID=999
