# Deployment-Artefakte (gebaute Tarballs)
dist/

# Backup vom migrierten agent-Submodule (lokal, nicht ins Repo)
.git-backup-agent/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# Secrets — Kunde-spezifisch, niemals ins Repo
.env
!.env.example
!*env.example

# Fernet-Key + Migrations-Backups (SEC-03) — niemals ins Repo
.secret_key
**/.secret_key
.migration-backup-*

# Zero-Config-Runtime-Verzeichnis (wird bei erstem Start von WebUI befüllt)
agent/config/*
!agent/config/.gitkeep

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Claude Code runtime state (worktrees, agent caches)
.claude/

# Local build artifacts
*.log
agent/.git.disabled/
